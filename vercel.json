{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/create-checkout-session.js": {
      "runtime": "nodejs18.x",
      "maxDuration": 30
    }
  }
}